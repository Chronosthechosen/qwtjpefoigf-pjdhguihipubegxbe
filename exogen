local loadedTracks = {}
--
function updateCloneAnimations()
    if not IllusionCloneTarget then return end
	if (LockedTarget and LockedTarget.Character) or (camlock_target and camlock_target.Character) then
		local target = LockedTarget or camlock_target

		local originalHum = target.Character:FindFirstChildOfClass("Humanoid")
		local cloneHum = IllusionCloneTarget:FindFirstChildOfClass("Humanoid")
		if not originalHum or not cloneHum then return end
		--
		local playingTracks = {}
		for _, track in pairs(originalHum:GetPlayingAnimationTracks()) do
			playingTracks[track.Animation] = track
		end
		--
		for anim, track in pairs(loadedTracks) do
			if not playingTracks[anim] then
				track:Stop()
				loadedTracks[anim] = nil
			end
		end
		--
		for anim, track in pairs(playingTracks) do
			local cloneTrack = loadedTracks[anim]
			if not cloneTrack then
				cloneTrack = cloneHum:LoadAnimation(anim)
				cloneTrack.Priority = Enum.AnimationPriority.Action
				cloneTrack:Play()
				cloneTrack:AdjustSpeed(0)
				loadedTracks[anim] = cloneTrack
			end
			loadedTracks[anim].TimePosition = track.TimePosition
		end
	end
end
