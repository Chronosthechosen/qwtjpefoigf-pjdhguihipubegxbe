		--
		local camPos = cam.CFrame.Position
		local screenPos, onScreen = cam:WorldToViewportPoint(predictedPos)
		--
		if camlock_shake_enabled then
			if (targetShake - currentShake).Magnitude < 0.01 then
				targetShake = Vector3.new(
					(math.random() - 0.5) * 2 * camlock_shake_intensity,
					(math.random() - 0.5) * 2 * camlock_shake_intensity,
					(math.random() - 0.5) * 2 * camlock_shake_intensity
				)
			end
			if camlock_smoothness_enabled then
				currentShake = currentShake:Lerp(targetShake, 0.9)
			else
				currentShake = targetShake
			end
		else
			currentShake = Vector3.new(0,0,0)
		end
		--
		local targetCFrame = CFrame.new(camPos + currentShake, predictedPos)
		--
		if camlock_smoothness_enabled then
			cam.CFrame = cam.CFrame:Lerp(targetCFrame, camlock_smoothness)
		else
			cam.CFrame = targetCFrame
		end
		--
		if show_predicted_position and IllusionCloneTarget then
			local cloneRoot = IllusionCloneTarget:FindFirstChild("HumanoidRootPart")
			if cloneRoot then
				cloneRoot.CFrame = CFrame.new(predictedPos, predictedPos + camlock_target.Character.HumanoidRootPart.CFrame.LookVector)
