RunService.Heartbeat:Connect(function(dt)
    if not random_offsets then return end
    --
    local Character = Player.Character or Player.CharacterAdded:Wait()
    local RootPart = Character:FindFirstChild("HumanoidRootPart")
    if not RootPart then return end
    --
    desync.old_position = RootPart.CFrame
    --
    local randX = math.random(0,360)
    local randY = math.random(0,360)
    local randZ = math.random(0,360)
    --
    desync.rotationX = desync.rotationX + randX * dt * rotationSpeed
    desync.rotationY = desync.rotationY + randY * dt * rotationSpeed
    desync.rotationZ = desync.rotationZ + randZ * dt * rotationSpeed
    --
    local offset = Vector3.new(
        math.random(-cframe_desync_range, cframe_desync_range),
        math.random(-cframe_desync_range, cframe_desync_range),
        math.random(-cframe_desync_range, cframe_desync_range)
    )
    --
    local rotationCFrame = CFrame.new()
    if random_rotation then
        rotationCFrame = CFrame.Angles(
            math.rad(desync.rotationX),
            math.rad(desync.rotationY),
            math.rad(desync.rotationZ)
        )
    end
    --
    RootPart.CFrame = RootPart.CFrame:ToWorldSpace(CFrame.new(offset) * rotationCFrame)
    if clone and cloneRoot then
        cloneRoot.CFrame = RootPart.CFrame:ToWorldSpace(CFrame.new(offset) * rotationCFrame)
    end
    RunService.RenderStepped:Wait()
    RootPart.CFrame = desync.old_position
end)

