function cframe_to_offset(origin, target)
    local actual_origin = origin * CFrame.new(0, -1, 0, 1, 0, 0, 0, 0, 1, 0, -1, 0)
    return actual_origin:ToObjectSpace(target):inverse()
end
--
function teleport_bullet(tool)
    if not getgenv().SilentAim or not bullet_tp then return end
    if not (LockedTarget and LockedTarget.Character and LockedTarget.Character:FindFirstChild("HumanoidRootPart")) then return end
	--
    local root = LockedTarget.Character.HumanoidRootPart
    local hand = client.Character and client.Character:FindFirstChild("RightHand")
    if not hand then return end
	--
    local original = tool.Grip
	--
	local grip_connections = getconnections(tool:GetPropertyChangedSignal("Grip"))
    for _, conn in ipairs(grip_connections) do
        conn:Disable()
    end
	--
    tool.Parent = client.Backpack
    tool.Grip = cframe_to_offset(hand.CFrame, root.CFrame)
    tool.Parent = client.Character
	--
    RunService.RenderStepped:Wait()
	--
    tool.Parent = client.Backpack
    tool.Grip = original
    tool.Parent = client.Character
end
--
function handle_character(char)
    if gun_connections.childadded then
        gun_connections.childadded:Disconnect()
    end
	--
    gun_connections.childadded = char.ChildAdded:Connect(function(tool)
        if tool:IsA("Tool") then
            if gun_connections.activate then
                gun_connections.activate:Disconnect()
            end
			--
            gun_connections.activate = tool.Activated:Connect(function()
                if bullet_tp then
                    teleport_bullet(tool)
                end
            end)
			--
			for _, conn in ipairs(getconnections(tool:GetPropertyChangedSignal("Grip"))) do
                conn:Disable()
            end
        end
    end)
end
--
handle_character(client.Character or client.CharacterAdded:Wait())
client.CharacterAdded:Connect(handle_character)
