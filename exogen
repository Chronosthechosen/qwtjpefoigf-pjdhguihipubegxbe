function createCloneForTarget(plr)
    if IllusionCloneTarget then
        IllusionCloneTarget:Destroy()
        IllusionCloneTarget = nil
    end

    if not plr or not plr.Character then return end

    local targetChar = plr.Character
    targetChar.Archivable = true
    local clone = targetChar:Clone()
    targetChar.Archivable = false

    clone.Name = ""
    clone.Parent = Workspace

    for _, part in pairs(clone:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Material = Enum.Material.ForceField
            part.Color = Color3.fromRGB(170, 85, 235)
            part.CanCollide = false
            part.Anchored = false
        end
    end

    local hum = clone:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.DisplayName = ""
        hum.NameDisplayDistance = 0
		hum.HealthDisplayType = Enum.HumanoidHealthDisplayType.AlwaysOff
    end

    IllusionCloneTarget = clone
end
