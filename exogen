--
function getPing()
    return math.floor(Player:GetNetworkPing() * 1000)
end
--
function getPrediction()
    if getgenv().AutoPrediction then
        local ping = getPing()
        local closest, best = math.huge, 0.14
        for k, v in pairs(PredictionMap) do
            local diff = math.abs(ping - k)
            if diff < closest then
                closest = diff
                best = v
            end
        end
        return Vector3.new(best, best, best)
    else
        return Vector3.new(getgenv().PredictionX, getgenv().PredictionY, getgenv().PredictionX)
    end
end
--
function getCamlockPrediction()
    if getgenv().AutoPrediction then
        local ping = getPing()
        local closest, best = math.huge, 0.14
        for k, v in pairs(PredictionMap) do
            local diff = math.abs(ping - k)
            if diff < closest then
                closest = diff
                best = v
            end
        end
        return best
    else
        return Vector3.new(getgenv().CamlockPredictionX, getgenv().CamlockPredictionY, getgenv().CamlockPredictionX)
    end
end
