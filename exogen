--
mt.__index = function(self, index)
    if not checkcaller() and self:IsA("Mouse") then
        if index == "Hit" then
            if (getgenv().SilentAim or getgenv().SilentAim1) and (LockedTarget and LockedTarget.Character) or (ragebottarget and ragebottarget.Character) then
                local target = ragebottarget or LockedTarget
                local part = target.Character[getgenv().CriticalParts[1]]
                if part then
                    return part.CFrame + (part.Velocity * getPrediction())
                end
            end
        end
    end
    return old_index(self, index)
end
